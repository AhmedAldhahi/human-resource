generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  EMPLOYEE
  HR
  ADMIN
}

enum CardType {
  BLUE_PLUS_30
  GREEN_PLUS_10
  YELLOW_MINUS_10
  RED_MINUS_30
}

enum AttendanceStatus {
  CLOCKED_IN
  CLOCKED_OUT
}

enum EmployeeType {
  FIXED
  PER_HOUR
}

enum WorkLocation {
  OFFICE
  HOME
}

enum AbsenceType {
  SICK_LEAVE
  REGULAR
  VACATION
  HOURLY_OFF
  EARLY_LEAVE
}

enum AbsenceStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id              String            @id @default(uuid())
  email           String            @unique
  password        String
  name            String
  role            Role              @default(EMPLOYEE)
  employeeType    EmployeeType      @default(FIXED)
  monthlySalary   Float             @default(0)
  photoUrl        String?
  absenceDaysLeft              Int               @default(28)
  sickDaysLeft                 Int               @default(14)
  vacationDaysLeft             Int               @default(14)
  earlyLeaveMinutesAccumulated Int               @default(0)
  netCardPoints                Int               @default(0)
  hourlyWage      Float             @default(0)
  phone           String?
  department      String?
  bio             String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  attendances     Attendance[]
  receivedCards   PerformanceCard[] @relation("ReceivedCards")
  issuedCards     PerformanceCard[] @relation("IssuedCards")
  absenceRecords  AbsenceRecord[]
}

model Attendance {
  id             String           @id @default(uuid())
  employeeId     String
  clockInTime    DateTime         @default(now())
  clockOutTime   DateTime?
  intendedTask   String
  status         AttendanceStatus @default(CLOCKED_IN)
  workLocation   WorkLocation     @default(OFFICE)
  latePenalty    Boolean          @default(false)
  penaltyMinutes Int              @default(0)

  employee       User             @relation(fields: [employeeId], references: [id])
}

model PerformanceCard {
  id         String   @id @default(uuid())
  employeeId String
  issuerId   String
  cardType   CardType
  reason     String
  issuedAt   DateTime @default(now())

  employee   User     @relation("ReceivedCards", fields: [employeeId], references: [id])
  issuer     User     @relation("IssuedCards", fields: [issuerId], references: [id])
}

model AbsenceRecord {
  id          String        @id @default(uuid())
  userId      String
  date        String        // YYYY-MM-DD
  type        AbsenceType   @default(REGULAR)
  status      AbsenceStatus @default(PENDING)
  reason      String?
  documentUrl       String?       // Path to medical certificate/doc for SICK_LEAVE
  earlyLeaveMinutes Int?          // Number of minutes/hours left early for EARLY_LEAVE
  isPaid            Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id])
}

