generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  EMPLOYEE
  HR
  ADMIN
}

enum CardType {
  GOLD_PLUS_50
  BLUE_PLUS_30
  GREEN_PLUS_10
  YELLOW_MINUS_10
  RED_MINUS_30
}

enum AttendanceStatus {
  CLOCKED_IN
  CLOCKED_OUT
}

enum EmployeeType {
  FIXED
  PER_HOUR
}

enum WorkLocation {
  OFFICE
  HOME
}

enum AbsenceType {
  SICK_LEAVE
  REGULAR
  VACATION
  HOURLY_OFF
  EARLY_LEAVE
}

enum AbsenceStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayrollStatus {
  DRAFT
  FINALIZED
}

model User {
  id              String            @id @default(uuid())
  email           String            @unique
  password        String
  name            String
  tsUsername       String?           @unique  // Windows login name for Tracker link
  role            Role              @default(EMPLOYEE)
  isActive        Boolean           @default(true)
  employeeType    EmployeeType      @default(FIXED)
  monthlySalary   Float             @default(0)
  photoUrl        String?
  absenceDaysLeft              Int               @default(28)
  sickDaysLeft                 Int               @default(14)
  vacationDaysLeft             Int               @default(14)
  earlyLeaveMinutesAccumulated Int               @default(0)
  netCardPoints                Int               @default(0)
  hourlyWage      Float             @default(0)
  phone           String?
  department      String?
  bio             String?
  customStatus    String?
  customEmoji     String?
  transportationAllowance Float @default(0)
  recurringBonus          Float @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  attendances     Attendance[]
  receivedCards   PerformanceCard[] @relation("ReceivedCards")
  issuedCards     PerformanceCard[] @relation("IssuedCards")
  absenceRecords  AbsenceRecord[]
  participations  ConversationParticipant[]
  sentMessages    Message[]
  payrollRecords  PayrollRecord[]
  auditLogs       AuditLog[]      @relation("AuditLogs")
}

model Attendance {
  id             String           @id @default(uuid())
  employeeId     String
  clockInTime    DateTime         @default(now())
  clockOutTime   DateTime?
  intendedTask   String
  status         AttendanceStatus @default(CLOCKED_IN)
  workLocation        WorkLocation     @default(OFFICE)
  latePenalty         Boolean          @default(false)
  penaltyMinutes      Int              @default(0)
  completedTasksCount Float?
  clockOutNote        String?
  authorizationName   String?
  isException         Boolean          @default(false)
  exceptionStatus     String? // e.g. PENDING, ACCEPTED, REJECTED

  employee            User             @relation(fields: [employeeId], references: [id])
}

model PerformanceCard {
  id         String   @id @default(uuid())
  employeeId String
  issuerId   String
  cardType   CardType
  reason     String
  issuedAt   DateTime @default(now())

  employee   User     @relation("ReceivedCards", fields: [employeeId], references: [id])
  issuer     User     @relation("IssuedCards", fields: [issuerId], references: [id])
}

model AbsenceRecord {
  id          String        @id @default(uuid())
  userId      String
  date        String        // YYYY-MM-DD
  type        AbsenceType   @default(REGULAR)
  status      AbsenceStatus @default(PENDING)
  reason      String?
  documentUrl       String?       // Path to medical certificate/doc for SICK_LEAVE
  earlyLeaveMinutes Int?          // Number of minutes/hours left early for EARLY_LEAVE
  isPaid            Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id])
}

model Conversation {
  id            String                    @id @default(uuid())
  title         String?
  isGroup       Boolean                   @default(false)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  participants  ConversationParticipant[]
  messages      Message[]
}

model ConversationParticipant {
  id               String       @id @default(uuid())
  conversationId   String
  userId           String
  joinedAt         DateTime     @default(now())
  lastReadAt       DateTime?

  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model PayrollRecord {
  id                      String        @id @default(uuid())
  userId                  String
  month                   String        // Format: YYYY-MM
  baseWage                Float
  transportationAllowance Float
  recurringBonus          Float
  approvedHours           Float
  transportationDeductions Float
  bonusAmount             Float
  bonusNotes              String?
  deductionAmount         Float
  deductionNotes          String?
  cardPointsReference     Int
  finalPayout             Float
  status                  PayrollStatus @default(FINALIZED)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  user                    User          @relation(fields: [userId], references: [id])
}

model AuditLog {
  id          String   @id @default(uuid())
  adminId     String
  action      String
  targetId    String?
  targetName  String?
  details     String
  createdAt   DateTime @default(now())

  admin       User     @relation("AuditLogs", fields: [adminId], references: [id])
}
